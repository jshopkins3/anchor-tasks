# ─── Auth (required — same Google OAuth client as Anchor Command) ─────────
# Use the SAME Google Client ID as Anchor Command so one OAuth consent screen covers both apps.
# GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Comma-separated list of Google emails allowed to use the app.
# ALLOWED_EMAILS=john@myanchormortgage.com,teammate@myanchormortgage.com

# ─── Railway (set automatically by Railway) ──────────────────────────────
# RAILWAY_ENVIRONMENT=production
# PORT=8080
